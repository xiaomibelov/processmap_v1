<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Food Process Copilot (MVP)</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="stylesheet" href="/static/styles.css" />
    <script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
  </head>
  <body>
    <div class="topbar">
      <div class="brand">Food Process Copilot (MVP)</div>
      <div class="meta">
        <span id="sessionMeta">session: —</span>
        <span id="llmMeta" class="llmMeta">ds: —</span>
        <button id="btnDeepseek">DeepSeek</button>
        <button id="btnSessions">Сессии</button>
        <button id="btnView">Вид: роли</button>
        <button id="btnNew">Новая сессия</button>
        <button id="btnExport">Экспорт как код</button>
      </div>
    </div>

    <div id="sessionModal" class="modal hidden" aria-hidden="true">
      <div class="modalBackdrop" data-act="close"></div>
      <div class="modalCard">
        <div class="modalTop">
          <div class="modalTitle">Сессии</div>
          <button id="sessClose" class="btnGhost" data-act="close">Закрыть</button>
        </div>
        <div class="modalBody">
          <div class="sessControls">
            <input id="sessSearch" placeholder="Поиск по названию / заметкам" />
            <button id="sessReload" class="btnGhost">Обновить</button>
          </div>
          <div id="sessList" class="sessList"></div>
          <div id="sessEmpty" class="hint" style="display:none; margin-top:10px;">Нет сохранённых сессий</div>
        </div>
      </div>
    </div>

    <div id="llmModal" class="modal hidden" aria-hidden="true">
      <div class="modalBackdrop" data-act="close"></div>
      <div class="modalCard" style="width: min(720px, calc(100vw - 24px));">
        <div class="modalTop">
          <div class="modalTitle">DeepSeek настройки</div>
          <button id="llmClose" class="btnGhost" data-act="close">Закрыть</button>
        </div>
        <div class="modalBody">
          <div class="hint">Ключ хранится локально в workspace (server-side). В API не возвращается.</div>
          <div style="height:10px;"></div>

          <div class="formGrid">
            <label>Base URL</label>
            <input id="llmBaseUrl" placeholder="https://api.deepseek.com" />

            <label>API key</label>
            <input id="llmApiKey" type="password" placeholder="sk-..." />

            <label>Режим</label>
            <select id="llmMode">
              <option value="strict">строгий технолог (дожимает пропуски)</option>
              <option value="soft">мягкий (больше вариативности)</option>
            </select>
          </div>

          <div class="row" style="margin-top:12px;">
            <button id="llmSave">Сохранить</button>
            <button id="llmClear" class="btnGhost">Очистить ключ</button>
            <span id="llmSaved" class="hint"></span>
          </div>

          <div class="hint" style="margin-top:10px;">
            Для генерации вопросов: кнопка «AI: докопать» под заметками.
          </div>
        </div>
      </div>
    </div>

    <div class="layout">
      <div class="panel">
        <div class="panelTitle">Заметки (в звонке)</div>
        <textarea id="notes" placeholder="Пиши тезисно. Можно с 'если/иначе', 'масса?', 'растворилось?'.
Добавляй оборудование через инспектор: kotel_1, skovoroda_1.
Добавляй длительности (мин) — тогда конфликты будут точнее."></textarea>
        <div class="row">
          <button id="btnSend">Отправить заметки</button>
          <button id="btnAiQuestions" class="btnGhost">AI: докопать</button>
          <span class="hint">Красный=критично, жёлтый=не хватает, синий=неясно/вариативно</span>
        </div>
      </div>

      <div class="panel">
        <div class="panelTitle">Процесс (Mermaid)</div>
        <div class="graphWrap" id="graphWrap">
          <div class="graphInner" id="graphInner">
            <pre class="mermaid" id="mermaid"></pre>
            <div id="graphOverlay" class="graphOverlay"></div>
          </div>
        </div>
        <div class="row">
          <span class="hint">Бейдж рядом с узлом = открытые вопросы. Клик по узлу или бейджу открывает поповер.</span>
        </div>
      </div>

      <div class="panel">
        <div class="panelTitle">Нормализатор</div>
        <div id="normalized" class="inspector"></div>

        <div class="panelTitle" style="margin-top:10px;">Оборудование и конфликты</div>
        <div id="resources" class="inspector"></div>

        <div class="panelTitle" style="margin-top:10px;">Инспектор узла</div>
        <div id="inspector" class="inspector"></div>
      </div>
    </div>

    <script src="/static/mod/notes_persist.js"></script>
  <script src="/static/mod/zoom.js"></script>
  <script src="/static/app.js"></script>
  
  <script src="/static/fpc/mermaid_zoom.js"></script>
</body>
</html>
