# Local/dev baseline template.
# Copy to `.env` and fill required values before first run.

# Required: compose / ports
HOST_PORT=8011
FRONTEND_PORT=5177
REDIS_PORT=6379
POSTGRES_PORT=5432

# Required: auth / workspace
PROCESS_WORKSPACE=workspace/processes
JWT_SECRET=change_me_jwt_secret
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=14
COOKIE_SECURE=0
COOKIE_SAMESITE=Lax

# Required: dev bootstrap account
DEV_SEED_ADMIN=1
ADMIN_EMAIL=change-me-admin@example.invalid
ADMIN_PASSWORD=change_me_admin_password

# Required: primary DB / Redis runtime
FPC_DB_BACKEND=postgres
POSTGRES_DB=processmap
POSTGRES_USER=fpc
POSTGRES_PASSWORD=change_me_postgres_password
DATABASE_URL=postgresql://fpc:change_me_postgres_password@postgres:5432/processmap
FPC_DB_POOL_MIN_SIZE=1
FPC_DB_POOL_MAX_SIZE=8
FPC_DB_STARTUP_CHECK=1
REDIS_URL=redis://redis:6379/0
REDIS_REQUIRED=1

# Optional: AI integration
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: local browser / API integration
CORS_ORIGINS=http://localhost:5177,http://127.0.0.1:5177

# Optional: storage / legacy sqlite mode
PROCESS_STORAGE_DIR=workspace/.session_store
PROJECT_STORAGE_DIR=workspace/projects
FPC_DB_MIGRATE_FILES=1
# PROCESS_DB_PATH=workspace/.session_store/processmap.sqlite3

# Optional: default org bootstrap
FPC_DEFAULT_ORG_ID=default
FPC_DEFAULT_ORG_NAME=Default Org
FPC_DEFAULT_WORKSPACE_NAME=Default Workspace

# Optional: enterprise invite / SMTP mode
INVITE_EMAIL_ENABLED=0
APP_BASE_URL=http://127.0.0.1:5177
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=true

# Optional: retention / rate limits
AUDIT_RETENTION_DAYS=90
INVITE_CLEANUP_KEEP_DAYS=30
RL_LOGIN_PER_MIN=30
RL_INVITES_PER_MIN=20
RL_ACCEPT_PER_MIN=30

# Optional: maintenance / support toggles
PATH_REPORT_SYNC_MODE=0
PATH_REPORT_STALE_RUNNING_SEC=900
REPORT_DEBUG_LOG=0
FPC_ENTERPRISE_INVITE_TOKEN_EXPOSE=0
