HOST_PORT=8011
FRONTEND_PORT=5177
DEEPSEEK_API_KEY=put_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
PROCESS_WORKSPACE=workspace/processes
JWT_SECRET=change_me_dev_secret
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=14
COOKIE_SECURE=0
COOKIE_SAMESITE=Lax
DEV_SEED_ADMIN=1
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin

# DB runtime:
# - postgres is the primary backend
# - switch to sqlite legacy mode with FPC_DB_BACKEND=sqlite
FPC_DB_BACKEND=postgres
DATABASE_URL=postgresql://fpc:fpc@postgres:5432/processmap
FPC_DB_POOL_MIN_SIZE=1
FPC_DB_POOL_MAX_SIZE=8
FPC_DB_STARTUP_CHECK=1

# Redis runtime (primary performance layer, required by default)
REDIS_URL=redis://redis:6379/0
REDIS_REQUIRED=1

# Postgres service params (docker-compose)
POSTGRES_DB=processmap
POSTGRES_USER=fpc
POSTGRES_PASSWORD=fpc
POSTGRES_PORT=5432

# Legacy sqlite-only knobs (used when FPC_DB_BACKEND=sqlite)
# PROCESS_STORAGE_DIR=workspace/.session_store
# PROCESS_DB_PATH=workspace/.session_store/processmap.sqlite3
