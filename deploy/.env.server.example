HOST_PORT=8011
FRONTEND_PORT=5177

DEEPSEEK_API_KEY=put_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

PROCESS_WORKSPACE=workspace/processes

JWT_SECRET=change_me_server_secret
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=14
COOKIE_SECURE=1
COOKIE_SAMESITE=Lax

DEV_SEED_ADMIN=0
