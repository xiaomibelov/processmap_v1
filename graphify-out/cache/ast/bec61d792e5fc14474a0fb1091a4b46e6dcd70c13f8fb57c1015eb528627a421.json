rce_file": "/opt/processmap-test/frontend/src/features/process/bpmn/save/saveBeforeSwitchDiagnostics.js", "source_location": "L90"}, {"caller_nid": "save_savebeforeswitchdiagnostics_classifybpmnsavefailure", "callee": "includes", "is_member_call": true, "source_file": "/opt/processmap-test/frontend/src/features/process/bpmn/save/saveBeforeSwitchDiagnostics.js", "source_location": "L94"}, {"caller_nid": "save_savebeforeswitchdiagnostics_classifybpmnsavefailure", "callee": "includes", "is_member_call": true, "source_file": "/opt/processmap-test/frontend/src/features/process/bpmn/save/saveBeforeSwitchDiagnostics.js", "source_location": "L94"}, {"caller_nid": "save_savebeforeswitchdiagnostics_buildbpmnsavefailuremessage", "callee": "(() => {\n    if (normalized === \"permission_denied\") return \"\u041d\u0435\u0442 \u043f\u0440\u0430\u0432 \u043d\u0430 \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0438\u0435 BPMN \u0434\u043b\u044f \u044d\u0442\u043e\u0439 \u0441\u0435\u0441\u0441\u0438\u0438.\";\n    if (normalized === \"conflict_detected\") return \"\u041a\u043e\u043d\u0444\u043b\u0438\u043a\u0442 \u0432\u0435\u0440\u0441\u0438\u0438 BPMN. \u041e\u0431\u043d\u043e\u0432\u0438\u0442\u0435 \u0441\u0435\u0441\u0441\u0438\u044e \u0438 \u043f\u043e\u0432\u0442\u043e\u0440\u0438\u0442\u0435 \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0438\u0435.\";\n    if (normalized === \"payload_invalid\") return \"\u041d\u0435\u043a\u043e\u0440\u0440\u0435\u043a\u0442\u043d\u044b\u0439 BPMN/XML payload: \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0438\u0435 \u043d\u0435 \u0432\u044b\u043f\u043e\u043b\u043d\u0435\u043d\u043e.\";\n    if (normalized === \"source_state_invalid\") return \"\u0421\u043e\u0441\u0442\u043e\u044f\u043d\u0438\u0435 BPMN \u0443\u0441\u0442\u0430\u0440\u0435\u043b\u043e \u0438\u043b\u0438 \u043d\u0435\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043b\u044c\u043d\u043e \u0434\u043b\u044f \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0438\u044f.\";\n    if (normalized === \"activation_unsupported\") return \"\u0422\u0435\u043a\u0443\u0449\u0438\u0439 \u0440\u0435\u0436\u0438\u043c \u043a\u043b\u0438\u0435\u043d\u0442\u0430 \u043d\u0435 \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442 \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0438\u0435 BPMN \u043f\u0435\u0440\u0435\u0434 \u043f\u0435\u0440\u0435\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u0435\u043c.\";\n    if (normalized === \"backend_error\") return \"Backend \u0432\u0435\u0440\u043d\u0443\u043b \u043e\u0448\u0438\u0431\u043a\u0443 \u043f\u0440\u0438 \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0438\u0438 BPMN.\";\n    return \"\u041d\u0435 \u0443\u0434\u0430\u043b\u043e\u0441\u044c \u0441\u043e\u0445\u0440\u0430\u043d\u0438\u0442\u044c BPMN \u043f\u0435\u0440\u0435\u0434 \u043f\u0435\u0440\u0435\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u0435\u043c \u0432\u043a\u043b\u0430\u0434\u043a\u0438.\";\n  })", "is_member_call": false, "source_file": "/opt/processmap-test/frontend/src/features/process/bpmn/save/saveBeforeSwitchDiagnostics.js", "source_location": "L100"}, {"caller_nid": "save_savebeforeswitchdiagnostics_buildbpmnsavefailuremessage", "callee": "includes", "is_member_call": true, "source_file": "/opt/processmap-test/frontend/src/features/process/bpmn/save/saveBeforeSwitchDiagnostics.js", "source_location": "L112"}, {"caller_nid": "save_savebeforeswitchdiagnostics_buildbpmnsavefailuremessage", "callee": "toLowerCase", "is_member_call": true, "source_file": "/opt/processmap-test/frontend/src/features/process/bpmn/save/saveBeforeSwitchDiagnostics.js", "source_location": "L112"}, {"caller_nid": "save_savebeforeswitchdiagnostics_buildbpmnsavefailuremessage", "callee": "toLowerCase", "is_member_call": true, "source_file": "/opt/processmap-test/frontend/src/features/process/bpmn/save/saveBeforeSwitchDiagnostics.js", "source_location": "L112"}, {"caller_nid": "save_savebeforeswitchdiagnostics_buildbpmnsavefailu