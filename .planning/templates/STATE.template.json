{
  "contour_id": "__CONTOUR_ID__",
  "created_at": "__CREATED_AT__",
  "updated_at": "__CREATED_AT__",
  "state": "ready_for_execution",
  "base_truth": "origin/main",
  "control_plane": ".planning/contours/__CONTOUR_ID__",
  "roles": {
    "planner": {
      "writes": [
        "STATE.json",
        "SOURCE_TRUTH.md",
        "PLAN.md",
        "WORKER_PROMPT.md",
        "REVIEWER_PROMPT.md",
        "READY_FOR_EXECUTION"
      ]
    },
    "worker": {
      "reads": [
        "PLAN.md",
        "WORKER_PROMPT.md"
      ],
      "writes": [
        "WORKER_STARTED",
        "WORKER_REPORT.md",
        "WORKER_DONE"
      ]
    },
    "reviewer": {
      "reads": [
        "PLAN.md",
        "WORKER_REPORT.md",
        "REVIEWER_PROMPT.md",
        "git diff",
        "runtime proof"
      ],
      "writes": [
        "REVIEW_REPORT.md",
        "REVIEW_PASS or CHANGES_REQUESTED"
      ]
    }
  },
  "markers": {
    "ready_for_execution": true,
    "worker_started": false,
    "worker_done": false,
    "review_pass": false,
    "changes_requested": false,
    "closed": false
  },
  "scope_guard": {
    "product_code_allowed": false,
    "bpmn_xml_allowed": false,
    "schema_allowed": false,
    "deploy_allowed": false
  }
}
