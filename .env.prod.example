## Production app overlay example.
## Copy to `.env.prod` and replace every `change_me_*` value.

# Required: compose / internal host ports
HOST_PORT=18011
FRONTEND_PORT=18080
REDIS_PORT=16379
POSTGRES_PORT=15432
EDGE_NETWORK_NAME=processmap_edge_net

# Required: runtime / auth
PROCESS_WORKSPACE=workspace/processes
JWT_SECRET=change_me_prod_jwt_secret
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=14
COOKIE_SECURE=1
COOKIE_SAMESITE=Lax
CORS_ORIGINS=https://processmap.ru

# Required: admin bootstrap policy
DEV_SEED_ADMIN=0
ADMIN_EMAIL=change-me-admin@example.invalid
ADMIN_PASSWORD=change_me_prod_admin_password

# Required: DB / Redis runtime
FPC_DB_BACKEND=postgres
POSTGRES_DB=processmap_prod
POSTGRES_USER=processmap_prod
POSTGRES_PASSWORD=change_me_prod_postgres_password
DATABASE_URL=postgresql://processmap_prod:change_me_prod_postgres_password@postgres:5432/processmap_prod
FPC_DB_POOL_MIN_SIZE=1
FPC_DB_POOL_MAX_SIZE=8
FPC_DB_STARTUP_CHECK=1
REDIS_URL=redis://redis:6379/0
REDIS_REQUIRED=1

# Optional: AI integration
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: public URLs used by smoke / invite links
APP_BASE_URL=https://processmap.ru
API_URL=http://127.0.0.1:18011
WEB_URL=http://127.0.0.1:18080

# Optional: storage / legacy sqlite mode
PROCESS_STORAGE_DIR=workspace/.session_store
PROJECT_STORAGE_DIR=workspace/projects
FPC_DB_MIGRATE_FILES=1

# Optional: enterprise invite / SMTP mode
INVITE_EMAIL_ENABLED=0
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=true

# Optional: retention / rate limits
AUDIT_RETENTION_DAYS=90
INVITE_CLEANUP_KEEP_DAYS=30
RL_LOGIN_PER_MIN=30
RL_INVITES_PER_MIN=20
RL_ACCEPT_PER_MIN=30

# Optional: maintenance / support toggles
PATH_REPORT_SYNC_MODE=0
PATH_REPORT_STALE_RUNNING_SEC=900
REPORT_DEBUG_LOG=0
FPC_ENTERPRISE_INVITE_TOKEN_EXPOSE=0
