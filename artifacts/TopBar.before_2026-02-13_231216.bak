export default function TopBar({
  backendStatus,
  backendHint,
  projects,
  projectId,
  onProjectChange,
  onDeleteProject,
  modeFilter,
  onModeFilterChange,
  sessions,
  sessionId,
  onOpenSession,
  onDeleteSession,
  onRefresh,
  onNewProject,
  onNewLocalSession,
  onNewBackendSession,
}) {
  const ok = backendStatus === "ok";
  const fail = backendStatus === "fail";

  return (
    <div className="topbar">
      <div className="topLeft">
        <div className="brand">Food Process Copilot</div>
        <div className={"statusChip " + (ok ? "ok" : fail ? "fail" : "")}>
          {ok ? "API OK" : fail ? "API FAIL" : "API …"}
        </div>
      </div>

      <div className="topRight">
        <div className="topGroup">
          <select
            className="select topSelect topSelect--project"
            value={projectId || ""}
            onChange={(e) => onProjectChange?.(e.target.value)}
            title="Проект"
          >
            {(!projects || projects.length === 0) ? <option value="">— проект —</option> : null}
            {(projects || []).map((p) => (
              <option key={p.id} value={p.id}>
                {p.title || p.id}
              </option>
            ))}
          </select>

          <button
            className="iconBtn danger"
            onClick={() => onDeleteProject?.()}
            title="Удалить проект"
            aria-label="Удалить проект"
            disabled={!projectId}
            type="button"
          >
            🗑
          </button>
        </div>

        <select
          className="select topSelect topSelect--mode"
          value={modeFilter || ""}
          onChange={(e) => onModeFilterChange?.(e.target.value)}
          title="Режим"
        >
          <option value="quick_skeleton">Quick</option>
          <option value="deep_audit">Deep</option>
        </select>

        <div className="topGroup">
          <select
            className="select topSelect topSelect--session"
            value={sessionId || ""}
            onChange={(e) => onOpenSession?.(e.target.value)}
            title="Сессия"
          >
            <option value="">— выбрать сессию —</option>
            {(sessions || []).map((s) => (
              <option key={s.id} value={s.id}>
                {s.title || s.id}
              </option>
            ))}
          </select>

          <button
            className="iconBtn danger"
            onClick={() => onDeleteSession?.()}
            title="Удалить сессию"
            aria-label="Удалить сессию"
            disabled={!sessionId}
            type="button"
          >
            🗑
          </button>
        </div>

        <button className="secondaryBtn smallBtn" onClick={() => onRefresh?.()} title={backendHint || ""} type="button">
          Обновить
        </button>

        <button className="secondaryBtn smallBtn" onClick={() => onNewProject?.()} type="button">
          Новый проект
        </button>

        <button className="secondaryBtn smallBtn" onClick={() => onNewLocalSession?.()} type="button">
          Новая (Local)
        </button>

        <button className="primaryBtn smallBtn" onClick={() => onNewBackendSession?.()} type="button">
          Новая (API)
        </button>
      </div>
    </div>
  );
}
