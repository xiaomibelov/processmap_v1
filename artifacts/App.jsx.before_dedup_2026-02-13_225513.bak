import { useEffect, useMemo, useState } from "react";

import AppShell from "./components/AppShell";
import NotesPanel from "./components/NotesPanel";
import NoSession from "./components/stages/NoSession";
import ActorsSetup from "./components/stages/ActorsSetup";
import ProjectWizardModal from "./components/ProjectWizardModal";

import { uid } from "./lib/ids";
import {
  apiMeta,
  apiListProjects,
  apiCreateProject,
  apiListProjectSessions,
  apiCreateProjectSession,
  apiListSessions,
  apiCreateSession,
  apiGetSession,
  apiPatchSession,
  apiPostNote,
  apiDeleteProject,
  apiDeleteSession,
} from "./lib/api";

function isLocalSessionId(id) {
  return typeof id === "string" && (id === "local" || id.startsWith("local_"));
}

function ensureArray(x) {
  return Array.isArray(x) ? x : [];
}

function ensureDraftShape(sessionId) {
  return {
    session_id: sessionId || null,
    title: "",
    roles: [],
    start_role: "",
    nodes: [],
    edges: [],
    notes: [],
    questions: [],
  };
}

function hasActors(draft) {
  const roles = ensureArray(draft?.roles).map((x) => String(x || "").trim()).filter(Boolean);
  const start = String(draft?.start_role || "").trim();
  return roles.length > 0 && !!start;
}

export default function App() {
  const [backendStatus, setBackendStatus] = useState("idle"); // idle|ok|fail
  const [backendHint, setBackendHint] = useState("");

  const [projects, setProjects] = useState([]);
  const [projectId, setProjectId] = useState("");
  const [modeFilter, setModeFilter] = useState("quick_skeleton");

  const [sessions, setSessions] = useState([]);
  const [draft, setDraft] = useState(ensureDraftShape(null));

  const [wizardOpen, setWizardOpen] = useState(false);
  const [reloadKey, setReloadKey] = useState(0);

  const [leftHidden, setLeftHidden] = useState(false);

  function markOk(hint) {
    setBackendStatus("ok");
    setBackendHint(String(hint || ""));
  }

  function markFail(err) {
    setBackendStatus("fail");
    setBackendHint(String(err || "API error"));
  }

  async function refreshMeta() {
    const r = await apiMeta();
    if (r.ok) {
      markOk("API OK");
      return;
    }
    markFail(r.error || "API FAIL");
  }

  async function refreshProjects() {
    const r = await apiListProjects();
    if (!r.ok) {
      markFail(r.error);
      return [];
    }
    const list = ensureArray(r.projects);
    setProjects(list);

    if (!projectId && list.length) {
      setProjectId(String(list[0]?.id || ""));
    }
    return list;
  }

  async function refreshSessions(nextProjectId) {
    const pid = String(nextProjectId !== undefined ? nextProjectId : projectId || "");
    const mode = String(modeFilter || "");

    let r;
    if (pid) {
      r = await apiListProjectSessions(pid);
    } else {
      r = await apiListSessions();
    }

    if (!r.ok) {
      markFail(r.error);
      setSessions([]);
      return [];
    }

    const list = ensureArray(r.sessions);
    const filtered = mode ? list.filter((s) => String(s?.mode || "") === mode) : list;

    setSessions(filtered);
    markOk(pid ? "API OK" : "API OK (legacy sessions)");
    return filtered;
  }

  useEffect(() => {
    refreshMeta();
    refreshProjects().then((list) => {
      const pid = list.length ? String(list[0]?.id || "") : "";
      refreshSessions(pid);
    });
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, []);

  const phase = useMemo(() => {
    const sid = draft?.session_id;
    if (!sid) return "no_session";
    if (!hasActors(draft)) return "actors_setup";
    return "interview";
  }, [draft]);

  const locked = phase !== "interview";

  async function openSession(sessionId) {
    const sid = String(sessionId || "");
    if (!sid) return;

    if (isLocalSessionId(sid)) {
      setDraft((d) => ({ ...(d || ensureDraftShape(null)), session_id: sid }));
      setReloadKey((x) => x + 1);
      return;
    }

    const r = await apiGetSession(sid);
    if (!r.ok) {
      markFail(r.error || "failed to load session");
      return;
    }

    setDraft({
      ...ensureDraftShape(sid),
      ...(r.session || {}),
      session_id: sid,
    });
    setReloadKey((x) => x + 1);
    markOk("API OK");
  }

  function patchDraft(mutator) {
    setDraft((prev) => {
      const base = prev ? JSON.parse(JSON.stringify(prev)) : ensureDraftShape(null);
      const out = typeof mutator === "function" ? mutator(base) : null;
      return out || base;
    });
  }

  function createLocalSession() {
    const sid = `local_${Date.now()}_${uid("s")}`;
    setDraft(ensureDraftShape(sid));
    setReloadKey((x) => x + 1);
  }

  async function createBackendSession(mode) {
    const m = String(mode || "quick_skeleton");
    if (projectId) {
      const r = await apiCreateProjectSession(projectId, m);
      if (!r.ok) {
        markFail(r.error);
        return;
      }
      await refreshSessions(projectId);
      await openSession(r.session_id);
      return;
    }

    const r = await apiCreateSession(m);
    if (!r.ok) {
      markFail(r.error);
      return;
    }
    await refreshSessions("");
    await openSession(r.session_id);
  }

  async function saveActors(next) {
    const roles = ensureArray(next?.roles).map((x) => String(x || "").trim()).filter(Boolean);
    const start_role = String(next?.start_role || "").trim();

    patchDraft((d) => {
      d.roles = roles;
      d.start_role = start_role;
      return d;
    });

    const sid = String(draft?.session_id || "");
    if (!sid || isLocalSessionId(sid)) return;

    const r = await apiPatchSession(sid, { roles, start_role });
    if (!r.ok) {
      markFail(r.error || "failed to patch session (roles)");
      return;
    }
    markOk("API OK");
  }

  async function deleteCurrentProject() {
    const pid = String(projectId || "").trim();
    if (!pid) return;
    const pTitle = (projects || []).find((p) => String(p?.id) === pid)?.title || pid;
    if (!window.confirm(`Удалить проект ""? Это удалит связанные сессии.`)) return;

    const r = await apiDeleteProject(pid);
    if (!r.ok) {
      markFail(r.error || "failed to delete project");
      return;
    }

    setProjectId("");
    setSessions([]);
    setDraft(ensureDraftShape(null));

    const list = await refreshProjects();
    const nextPid = list.length ? String(list[0]?.id || "") : "";
    setProjectId(nextPid);
    await refreshSessions(nextPid);
    markOk("API OK");
  }

  async function deleteCurrentSession() {
    const sid = String(draft?.session_id || "").trim();
    if (!sid) return;
    if (isLocalSessionId(sid)) {
      setDraft(ensureDraftShape(null));
      return;
    }

    const sTitle = (sessions || []).find((s) => String(s?.id) === sid)?.title || sid;
    if (!window.confirm(`Удалить сессию ""?`)) return;

    const r = await apiDeleteSession(sid);
    if (!r.ok) {
      markFail(r.error || "failed to delete session");
      return;
    }

    setDraft(ensureDraftShape(null));
    await refreshSessions(projectId);
    markOk("API OK");
  }

  async function addNote(text) {
    const t = String(text || "").trim();
    if (!t) return { ok: false, error: "empty" };

    patchDraft((d) => {
      const arr = ensureArray(d.notes);
      arr.push({
        id: uid("note"),
        text: t,
        ts: new Date().toISOString(),
      });
      d.notes = arr;
      return d;
    });

    const sid = String(draft?.session_id || "");
    if (!sid || isLocalSessionId(sid)) return { ok: true, status: 200 };

    const r = await apiPostNote(sid, { text: t });
    if (!r.ok) {
      markFail(r.error || "failed to post note");
      return r;
    }
    markOk("API OK");
    return r;
  }

  async function createProjectFromWizard(payload) {
    const title = String(payload?.title || "").trim();
    if (!title) return;

    const passport = payload?.passport || {};
    const firstMode = String(payload?.mode || "quick_skeleton");

    const r = await apiCreateProject({
      title,
      passport,
    });

    if (!r.ok) {
      markFail(r.error || "failed to create project");
      return;
    }

    const newProjectId = String(r.project_id || "");
    if (!newProjectId) {
      markFail("project_id missing in response");
      return;
    }

    setWizardOpen(false);
    await refreshProjects();
    setProjectId(newProjectId);

    const rs = await apiCreateProjectSession(newProjectId, firstMode);
    if (!rs.ok) {
      markFail(rs.error || "failed to create project session");
      return;
    }

    await refreshSessions(newProjectId);
    await openSession(String(rs.session_id || ""));
  }

  const left = useMemo(() => {
    if (phase === "no_session") {
      return (
        <NoSession
          backendStatus={backendStatus}
          backendHint={backendHint}
          onNewBackendSession={() => createBackendSession(modeFilter)}
          onNewLocalSession={createLocalSession}
        />
      );
    }

    if (phase === "actors_setup") {
      return <ActorsSetup draft={draft} onSaveActors={saveActors} />;
    }

    return <NotesPanel draft={draft} onAddNote={addNote} disabled={locked} />;
  }, [phase, backendStatus, backendHint, draft, modeFilter, locked]);

  return (
    <>
      <AppShell
        draft={draft}
        locked={locked}
        left={left}
        leftHidden={leftHidden}
        onToggleLeft={() => setLeftHidden((x) => !x)}
        onPatchDraft={patchDraft}
        reloadKey={reloadKey}
        backendStatus={backendStatus}
        backendHint={backendHint}
        projects={projects}
        projectId={projectId}
        onProjectChange={async (pid) => {
          const next = String(pid || "");
          setProjectId(next);
          await refreshSessions(next);
        }}
        onDeleteProject={deleteCurrentProject}
        modeFilter={modeFilter}
        onModeFilterChange={async (m) => {
          const next = String(m || "");
          setModeFilter(next);
          await refreshSessions(projectId);
        }}
        sessions={sessions}
        sessionId={String(draft?.session_id || "")}
        onOpenSession={openSession}
        onDeleteSession={deleteCurrentSession}
        onRefresh={async () => {
          await refreshProjects();
          await refreshSessions(projectId);
        }}
        onNewProject={() => setWizardOpen(true)}
        onNewLocalSession={createLocalSession}
        onNewBackendSession={() => createBackendSession(modeFilter)}
      />

      <ProjectWizardModal open={wizardOpen} onClose={() => setWizardOpen(false)} onCreate={createProjectFromWizard} />
    </>
  );
}
