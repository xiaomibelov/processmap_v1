/* fpc: delete_endpoints_v1 */
export async function apiDeleteProject(projectId) {
  const id = String(projectId || "").trim();
  if (!id) return { ok: false, error: "missing project_id" };
  return request(`/api/projects/${encodeURIComponent(id)}`, { method: "DELETE" });
}

export async function apiDeleteSession(sessionId) {
  const id = String(sessionId || "").trim();
  if (!id) return { ok: false, error: "missing session_id" };
  return request(`/api/sessions/${encodeURIComponent(id)}`, { method: "DELETE" });
}
