const API_BASE = ""; // use Vite proxy: /api -> backend

function isJsonResponse(res) {
  const ct = res.headers.get("content-type") || "";
  return ct.includes("application/json") || ct.includes("+json");
}

async function safeReadBody(res) {
  try {
    if (isJsonResponse(res)) return await res.json();
    return await res.text();
  } catch (e) {
    return null;
  }
}

function normErr(payload, fallback) {
  if (!payload) return fallback;
  if (typeof payload === "string") return payload || fallback;
  if (payload.detail && Array.isArray(payload.detail) && payload.detail.length) {
    const first = payload.detail[0];
    if (typeof first === "string") return first;
    if (first && typeof first.msg === "string") return first.msg;
  }
  if (typeof payload.error === "string") return payload.error;
  return fallback;
}

async function request(path, opts = {}) {
  const url = `${API_BASE}${path}`;
  const method = (opts.method || "GET").toUpperCase();

  const headers = new Headers(opts.headers || {});
  if (opts.json !== undefined) {
    headers.set("content-type", "application/json");
  }

  let body = opts.body;
  if (opts.json !== undefined) {
    body = JSON.stringify(opts.json);
  }

  let res;
  try {
    res = await fetch(url, { method, headers, body, credentials: "same-origin" });
  } catch (e) {
    return { ok: false, status: 0, error: String(e?.message || e), body: null };
  }

  const payload = await safeReadBody(res);
  if (!res.ok) {
    return { ok: false, status: res.status, error: normErr(payload, `HTTP ${res.status}`), body: payload };
  }
  return { ok: true, status: res.status, body: payload };
}

function listFrom(body, key) {
  if (Array.isArray(body)) return body;
  if (body && Array.isArray(body[key])) return body[key];
  if (body && Array.isArray(body.items)) return body.items;
  return [];
}

/* System / Meta */
export async function apiMeta() {
  const r = await request("/api/meta");
  return r.ok ? { ok: true, status: r.status } : r;
}

/* Projects */
export async function apiListProjects() {
  const r = await request("/api/projects");
  if (!r.ok) return r;
  return { ok: true, projects: listFrom(r.body, "projects") };
}

export async function apiCreateProject(payload) {
  const r = await request("/api/projects", { method: "POST", json: payload || {} });
  if (!r.ok) return r;
  const id = String(r.body?.project_id || r.body?.id || "");
  return { ok: true, project_id: id, body: r.body };
}

export async function apiPatchProject(projectId, patch) {
  const pid = String(projectId || "");
  const r = await request(`/api/projects/${pid}`, { method: "PATCH", json: patch || {} });
  return r.ok ? { ok: true, body: r.body } : r;
}

export async function apiDeleteProject(projectId) {
  const pid = String(projectId || "");
  const r = await request(`/api/projects/${pid}`, { method: "DELETE" });
  return r.ok ? { ok: true, body: r.body } : r;
}

/* Project Sessions */
export async function apiListProjectSessions(projectId) {
  const pid = String(projectId || "");
  const r = await request(`/api/projects/${pid}/sessions`);
  if (!r.ok) return r;
  return { ok: true, sessions: listFrom(r.body, "sessions") };
}

export async function apiCreateProjectSession(projectId, mode) {
  const pid = String(projectId || "");
  const m = String(mode || "quick_skeleton");
  const r = await request(`/api/projects/${pid}/sessions?mode=${encodeURIComponent(m)}`, {
    method: "POST",
    json: { title: `Session (${m})` },
  });
  if (!r.ok) return r;
  const sid = String(r.body?.session_id || r.body?.id || "");
  return { ok: true, session_id: sid, body: r.body };
}

/* Sessions */
export async function apiListSessions() {
  const r = await request("/api/sessions");
  if (!r.ok) return r;
  return { ok: true, sessions: listFrom(r.body, "sessions") };
}

export async function apiCreateSession(mode) {
  const m = String(mode || "quick_skeleton");
  const r = await request(`/api/sessions`, { method: "POST", json: { title: `Session (${m})` } });
  if (!r.ok) return r;
  const sid = String(r.body?.session_id || r.body?.id || "");
  return { ok: true, session_id: sid, body: r.body };
}

export async function apiGetSession(sessionId) {
  const sid = String(sessionId || "");
  const r = await request(`/api/sessions/${sid}`);
  if (!r.ok) return r;
  return { ok: true, session: r.body };
}

export async function apiPatchSession(sessionId, patch) {
  const sid = String(sessionId || "");
  const r = await request(`/api/sessions/${sid}`, { method: "PATCH", json: patch || {} });
  return r.ok ? { ok: true, body: r.body } : r;
}

export async function apiDeleteSession(sessionId) {
  const sid = String(sessionId || "");
  const r = await request(`/api/sessions/${sid}`, { method: "DELETE" });
  return r.ok ? { ok: true, body: r.body } : r;
}

/* Session: Notes / Derived / Export */
export async function apiPostNote(sessionId, payload) {
  const sid = String(sessionId || "");
  const notes = String(payload?.notes || payload?.text || "").trim();
  const r = await request(`/api/sessions/${sid}/notes`, { method: "POST", json: { notes } });
  return r.ok ? { ok: true, body: r.body } : r;
}

export async function apiRecompute(sessionId) {
  const sid = String(sessionId || "");
  const r = await request(`/api/sessions/${sid}/recompute`, { method: "POST" });
  return r.ok ? { ok: true, body: r.body } : r;
}

export async function apiGetAnalytics(sessionId) {
  const sid = String(sessionId || "");
  const r = await request(`/api/sessions/${sid}/analytics`);
  return r.ok ? { ok: true, analytics: r.body } : r;
}

export async function apiGetBpmnXml(sessionId) {
  const sid = String(sessionId || "");
  const r = await request(`/api/sessions/${sid}/bpmn`);
  if (!r.ok) return r;
  const xml = typeof r.body === "string" ? r.body : "";
  return { ok: true, xml };
}

export async function apiGetExport(sessionId) {
  const sid = String(sessionId || "");
  const r = await request(`/api/sessions/${sid}/export`);
  return r.ok ? { ok: true, export: r.body } : r;
}

