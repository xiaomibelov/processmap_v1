# BPMN 123: локальное Docker-окружение.
# Для локальных переопределений можно скопировать в .env.bpmn123.local.
# Секреты коммитить нельзя.

BPMN123_FRONTEND_PORT=5177
BPMN123_VITE_PORT=5177
BPMN123_VITE_HMR_PORT=5177
BPMN123_VITE_ALLOWED_HOSTS=localhost,127.0.0.1

# Backend намеренно не запускается в этом контуре.
# Значение нужно только как placeholder для будущего локального API.
BPMN123_API_PROXY_TARGET=http://host.docker.internal:8087
