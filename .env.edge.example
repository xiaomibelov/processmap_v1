## Shared public edge example.
## Copy to `.env.edge` before deploying the shared 80/443 ingress layer.

EDGE_NETWORK_NAME=processmap_edge_net
EDGE_HTTP_PORT=80
EDGE_HTTPS_PORT=443
LETSENCRYPT_DIR=/etc/letsencrypt
ACME_WEBROOT_DIR=./runtime/edge/acme
PROD_SERVER_NAME=processmap.ru
STAGE_SERVER_NAME=stage.processmap.ru
EDGE_ENABLE_STAGE=0
CERTBOT_EMAIL=change-me-ops@example.invalid
